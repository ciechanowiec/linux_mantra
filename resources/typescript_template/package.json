{
    "name": "typescript-template",
    "version": "1.0.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@11.0.9",
    "engines": {
        "node": ">=24"
    },
    "scripts": {
        "typecheck": "tsc --noEmit -p tsconfig.test.json",
        "lint": "biome lint .",
        "format": "biome format --write .",
        "check": "biome check . && pnpm run typecheck && vitest run",
        "build": "pnpm run check && tsc",
        "build:force": "tsc --noEmitOnError false || true",
        "test": "vitest run",
        "prepare": "git rev-parse --is-inside-work-tree >/dev/null 2>&1 && simple-git-hooks || true"
    },
    "simple-git-hooks": {
        "pre-commit": "pnpm exec biome check --staged --no-errors-on-unmatched"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.14",
        "@types/node": "^24.12.3",
        "simple-git-hooks": "^2.13.1",
        "typescript": "^6.0.3",
        "vitest": "^4.1.5"
    }
}
